# === OpenAI ===
OPENAI_API_KEY=sk-...

# Modelo del agente (el workflow original usa gpt-5.1)
OPENAI_MODEL=gpt-5.1
# Modelo de visión para imágenes
OPENAI_VISION_MODEL=gpt-4o-mini
# Modelo de transcripción de audios
OPENAI_TRANSCRIBE_MODEL=whisper-1

# === ManyChat ===
# Token de la API de ManyChat (Settings -> API en ManyChat). Formato: "PAGEID:hash"
MANYCHAT_TOKEN=PEGA_AQUI_TU_TOKEN_DE_MANYCHAT
# Canal por defecto: instagram | whatsapp | telegram
MANYCHAT_CHANNEL=instagram

# === WhatsApp por CRM a medida (opcional) ===
# Si pones esta URL, los mensajes de WhatsApp se envían con un POST a tu CRM
# ({ to, text, channel }) en vez de por ManyChat. Déjalo vacío para usar ManyChat.
WHATSAPP_OUTBOUND_URL=
WHATSAPP_OUTBOUND_TOKEN=

# === Servidor ===
PORT=3000

# === Aviso por email cuando se deriva un lead ===
NOTIFY_EMAIL=dcasero8@gmail.com
# SMTP para enviar el aviso (ej. Gmail con "contraseña de aplicación")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=contraseña_de_aplicacion_de_16_letras
# Remitente que verá el destinatario (opcional)
SMTP_FROM=Agente Instagram <tu-correo@gmail.com>

# === Login del panel (Basic Auth) ===
# Protege el panel en un dominio público. Si lo dejas vacío, el panel queda abierto.
ADMIN_USER=admin
ADMIN_PASS=
# Secreto que ManyChat debe mandar en la cabecera "x-webhook-token" (opcional, recomendado).
# Déjalo vacío para no exigir cabecera.
WEBHOOK_TOKEN=

# Segundos de espera para agrupar mensajes seguidos del lead antes de responder (buffer/debounce)
BUFFER_SECONDS=8

# === Comportamiento humano (respuestas no instantáneas) ===
# Tiempo de "lectura" antes de empezar a responder (aleatorio entre min y max)
READING_MIN_SECONDS=2
READING_MAX_SECONDS=5
# Tiempo de "tipeo" por mensaje = nº de letras * segundos/letra (acotado entre min y max)
TYPING_SECONDS_PER_LETTER=0.045
TYPING_MIN_SECONDS=1.5
TYPING_MAX_SECONDS=12
# Pausa natural entre un mensaje y el siguiente (aleatorio entre min y max)
PART_PAUSE_MIN_SECONDS=0.8
PART_PAUSE_MAX_SECONDS=2
